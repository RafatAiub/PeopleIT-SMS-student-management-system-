# =============================================================================
# PeopleIT SMS — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME="PeopleIT SMS"
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=sms_pass
POSTGRES_DB=sms_db
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=sms_redis_pass
REDIS_URL="redis://default:PASSWORD@HOST:6379"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Payment Gateways (disabled by default — enable per institution) ───────────
# bKash
BKASH_ENABLED=false
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# Nagad
NAGAD_ENABLED=false
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_MERCHANT_PUBLIC_KEY=
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

# SSL Commerz
SSLCOMMERZ_ENABLED=false
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# ── SMS Gateway ───────────────────────────────────────────────────────────────
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Greenweb (used for fee-due and absence reminder SMS — see reminderWorker.ts)
GREENWEB_API_TOKEN=
GREENWEB_BASE_URL=https://api.greenweb.com.bd/api.php

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="PeopleIT SMS <noreply@peopleit.com>"

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# For S3/R2:
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
