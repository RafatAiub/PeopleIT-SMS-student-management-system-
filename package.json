{
  "name": "peopleit-sms",
  "version": "1.0.0",
  "private": true,
  "description": "PeopleIT SMS — AI-Powered Multi-Tenant Student Management System",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspace=frontend",
    "typecheck": "npm run typecheck --workspace=backend && npm run typecheck --workspace=frontend",
    "migrate": "npm run migrate --workspace=backend",
    "migrate:reset": "npm run migrate:reset --workspace=backend",
    "db:studio": "npm run db:studio --workspace=backend",
    "lint": "npm run lint --workspace=backend && npm run lint --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "playwright": "^1.61.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
